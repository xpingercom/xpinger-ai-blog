# 글 생성용. 없으면 mock 모드로 동작합니다.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=

# Supabase 저장/발행/광고 관리용
# DATABASE_URL은 SQL 클라이언트용이고, 이 앱의 런타임 저장 기능은 Supabase REST URL과 service role key를 사용합니다.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# 추후 트렌드 수집 연결용
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

NEXT_PUBLIC_SITE_URL=https://xpinger.com
CRON_SECRET=change-me

ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password
